      "dark": "text950",
      "light": "text50"
    },
    "syntaxComment": {
      "dark": "bg400",
      "light": "bg400"
    },
    "syntaxKeyword": {
      "dark": "secondary700",
      "light": "secondary500"
    },
    "syntaxFunction": {
      "dark": "primary500",
      "light": "primary400"
    },
    "syntaxVariable": {
      "dark": "text800",
      "light": "text700"
    },
    "syntaxString": {
      "dark": "primary700",
      "light": "primary500"
    },
    "syntaxNumber": {
      "dark": "accent700",
      "light": "accent500"
    },
    "syntaxType": {
      "dark": "secondary800",
      "light": "secondary600"
    },
    "syntaxOperator": {
      "dark": "secondary700",
      "light": "secondary500"
    },
    "syntaxPunctuation": {
      "dark": "text950",
      "light": "text50"
    }
