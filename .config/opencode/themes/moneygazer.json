  "theme": {
    "primary": {
      "dark": "primary500",
      "light": "primary400"
    },
    "secondary": {
      "dark": "secondary600",
      "light": "secondary500"
    },
    "accent": {
      "dark": "accent600",
      "light": "accent500"
    },
    "error": {
      "dark": "red",
      "light": "red"
    },
    "warning": {
      "dark": "primary600",
      "light": "primary500"
    },
    "success": {
      "dark": "green",
      "light": "green"
    },
    "info": {
      "dark": "secondary700",
      "light": "secondary600"
    },
    "text": {
      "dark": "text950",
      "light": "text50"
    },
    "textMuted": {
      "dark": "text800",
      "light": "text600"
    },
    "background": {
      "dark": "bg50",
      "light": "bg950"
    },
    "backgroundPanel": {
      "dark": "bg100",
      "light": "bg800"
    },
    "backgroundElement": {
      "dark": "bg200",
      "light": "bg700"
    },
    "border": {
      "dark": "bg300",
      "light": "bg400"
    },
    "borderActive": {
      "dark": "bg400",
      "light": "bg300"
