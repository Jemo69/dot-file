{
  "$schema": "https://opencode.ai/theme.json",

  "defs": {
    "text50": "#020818",
    "text600": "#3f72f3",
    "text700": "#6f95f6",
    "text800": "#9fb9f9",
    "text900": "#cfdcfc",
    "text950": "#B2C3E6",
    "bg50": "#060b13",
    "bg100": "#0c1527",
    "bg200": "#192a4d",
    "bg300": "#253f74",
    "bg400": "#32559a",
    "bg700": "#8ba5da",
    "bg800": "#b2c3e6",
    "bg950": "#ecf0f9",
    "primary400": "#ca7d02",
    "primary500": "#fc9d03",
    "primary600": "#fdb035",
    "primary700": "#fdc468",
    "primary800": "#fed89a",
    "secondary400": "#430ebe",
    "secondary500": "#5412ed",
    "secondary600": "#7641f1",
    "secondary700": "#9871f4",
    "secondary800": "#baa0f8",
    "accent500": "#8a12ed",
    "accent600": "#a241f1",
    "accent700": "#b971f4",
    "accent800": "#d0a0f8",
    "red": "#BF616A",
    "green": "#A3BE8C"
