      "dark": "text950",
      "light": "text50"
    },
    "markdownHeading": {
      "dark": "primary500",
      "light": "primary400"
    },
    "markdownLink": {
      "dark": "secondary700",
      "light": "secondary500"
    },
    "markdownLinkText": {
      "dark": "accent700",
      "light": "accent600"
    },
    "markdownCode": {
      "dark": "primary700",
      "light": "primary500"
    },
    "markdownBlockQuote": {
      "dark": "bg300",
      "light": "bg400"
    },
    "markdownEmph": {
      "dark": "accent700",
      "light": "accent500"
    },
    "markdownStrong": {
      "dark": "primary600",
      "light": "primary400"
    },
    "markdownHorizontalRule": {
      "dark": "bg300",
      "light": "bg400"
    },
    "markdownListItem": {
      "dark": "primary500",
      "light": "primary400"
